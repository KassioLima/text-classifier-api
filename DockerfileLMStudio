# Usar uma imagem base com Linux
FROM ubuntu:20.04

# Definir variáveis de ambiente para evitar prompts interativos
ENV DEBIAN_FRONTEND=noninteractive

# Instalar dependências necessárias
RUN apt-get clean && apt-get update && apt-get install -y \
    wget \
    curl \
    libfuse2 \
    fuse \
    && apt-get clean

# Criar diretório de trabalho
WORKDIR /app

# Copiar o AppImage para dentro do contêiner
COPY LM-Studio-0.3.9-5-x64.AppImage /app/LM-Studio.AppImage

# Tornar o AppImage executável
RUN chmod +x /app/LM-Studio.AppImage

# Extrair o conteúdo do AppImage
RUN /app/LM-Studio.AppImage --appimage-extract

# Expor a porta da API (ajuste conforme necessário)
EXPOSE 8080

# Comando para rodar o LM Studio extraído
CMD ["/app/squashfs-root/lm-studio", "--no-gui", "--api"]
